<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mmyf.commons.mapper.code.CodeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mmyf.commons.model.entity.code.Code">
        <id column="c_pid" property="pid"/>
        <id column="c_code" property="code"/>
        <result column="c_name" property="name"/>
        <result column="c_levelinfo" property="levelinfo"/>
        <result column="c_valid" property="valid"/>
        <result column="n_order" property="nOrder"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        c_pid, c_code, c_name, c_levelinfo, c_valid, n_order
    </sql>

</mapper>
