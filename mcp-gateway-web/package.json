{
	"name": "payment-platform",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "rm -rf dist && npm run lint &&  nuxt dev --open --host --port 3666",
		"devwin": "rimraf dist && npm run lint && nuxt dev --open --host --port 3666",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"prepare": "husky install",
		"lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore && prettier --write ."
	},
	"lint-staged": {
		"**/*": "prettier --write --ignore-unknown"
	},
	"devDependencies": {
		"@nuxtjs/eslint-config": "^12.0.0",
		"@nuxtjs/eslint-config-typescript": "^12.1.0",
		"@nuxtjs/tailwindcss": "^6.11.2",
		"unstorage": "^1.10.1",
		"@vueuse/core": "^10.7.2",
		"ant-design-vue": "^4.1.2",
		"axios": "^1.6.7",
		"clipboard": "^2.0.11",
		"dayjs": "^1.11.10",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"highlight.js": "^11.9.0",
		"husky": "^9.0.11",
		"lint-staged": "^15.2.2",
		"nuxt": "^3.10.3",
		"prettier": "3.2.5",
		"remixicon": "^4.1.0",
		"sass": "^1.70.0",
		"scp2": "^0.5.0",
		"typescript": "5.0.4",
		"vue": "^3.4.15",
		"vue-draggable-next": "^2.2.1",
		"vue-eslint-parser": "^9.4.2",
		"vue-router": "^4.2.5"
	},
	"dependencies": {
		"number-precision": "^1.6.0"
	}
}
